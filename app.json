{
  "expo": {
    "name": "Cabanga+",
    "slug": "cabanga-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "be.scolares.cabangamobile",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "icon": "./assets/favicons/favicon-512x512.png",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicons/favicon-512x512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mael.cabangamobile",
      "predictiveBackGestureEnabled": false,
      "runtimeVersion": "1.0.0"
    },
    "splash": {
      "image": "./assets/favicons/favicon-512x512.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "e7b8f2fa-3860-42f3-bf58-4e1264b5c821"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/e7b8f2fa-3860-42f3-bf58-4e1264b5c821"
    }
  }
}
